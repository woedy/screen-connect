# ==============================================
# ScreenConnect Environment Variables
# ==============================================
# Copy this file to .env and modify values.
# In Coolify, add these in the 'Environment Variables' tab.

# --- Django Core ---
DJANGO_SECRET_KEY=change-this-to-a-random-64-char-string
DEBUG=False
ALLOWED_HOSTS=*

# --- PostgreSQL ---
# Used by both 'db' service and 'web'/'celery' services.
POSTGRES_DB=screenconnect
POSTGRES_USER=screenconnect
POSTGRES_PASSWORD=change-this-to-a-secure-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Redis & Celery ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# --- Security & Networking ---
# Local: http://localhost:3000,http://localhost:5173
# Production: https://admin.yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# --- App Settings ---
SESSION_EXPIRY_HOURS=2

# ==============================================
# Coolify Setup Notes:
# 1. Provide VITE_API_BASE_URL to the frontend build arg
#    if your API is on a separate subdomain.
# 2. Add 'DOMAIN' for the frontend service in Coolify UI.
# ==============================================
