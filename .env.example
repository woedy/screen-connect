# ==============================================
# ScreenConnect Environment Variables
# ==============================================
# Copy this file to .env and modify values

# Django
DJANGO_SECRET_KEY=change-this-to-a-random-64-char-string
DEBUG=False
ALLOWED_HOSTS=*

# PostgreSQL
POSTGRES_DB=screenconnect
POSTGRES_USER=screenconnect
POSTGRES_PASSWORD=change-this-to-a-secure-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# CORS (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Session expiry (hours)
SESSION_EXPIRY_HOURS=2
